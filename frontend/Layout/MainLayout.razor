@inherits LayoutComponentBase
<MudThemeProvider Theme="@Theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="kanban-appbar">
        <MudText Typo="Typo.h6" Class="kanban-brand">Kanban</MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="kanban-subtitle">Single board</MudText>
    </MudAppBar>

    <MudMainContent Class="kanban-main">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private static readonly MudTheme Theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#209dd7",
            Secondary = "#753991",
            Tertiary = "#ecad0a",
            AppbarBackground = "#032147",
            Background = "#f6f8fc",
            Surface = "#ffffff",
            TextPrimary = "#032147",
            TextSecondary = "#888888",
            LinesDefault = "rgba(3, 33, 71, 0.12)"
        }
    };
}
